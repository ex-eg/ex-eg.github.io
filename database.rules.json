{
  "rules": {
    ".read": false,
    ".write": false,

    "config": {
      ".read": false,
      ".write": false,
      "adminEmail": {
        ".read": "auth != null",
        ".write": "auth != null && ( ( !data.exists() && newData.val() === auth.token.email ) || data.val() === auth.token.email )",
        ".validate": "newData.isString() && newData.val().length <= 160"
      },
      "adminGate": {
        ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        ".validate": "newData.hasChildren(['salt','hash'])",
        "salt": { ".validate": "newData.isString() && newData.val().length <= 64" },
        "hash": { ".validate": "newData.isString() && newData.val().length <= 128" },
        "at":   { ".validate": "!newData.exists() || newData.isNumber()" },
        "$other": { ".validate": false }
      },
      "imgbbKeys": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        "$i": { ".validate": "newData.isString() && newData.val().length <= 200" }
      },
      "captchaKeys": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        "$i": { ".validate": "newData.isString() && newData.val().length <= 120" }
      },
      "dbUrls": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        "$i": { ".validate": "newData.isString() && newData.val().length <= 300" }
      },
      "emailKeys": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        "$i": {
          ".validate": "newData.hasChildren(['publicKey','serviceId','templateId'])",
          "publicKey":        { ".validate": "newData.isString() && newData.val().length <= 120" },
          "serviceId":        { ".validate": "newData.isString() && newData.val().length <= 120" },
          "templateId":       { ".validate": "newData.isString() && newData.val().length <= 120" },
          "notifyTemplateId": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 120)" },
          "toEmail":          { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
          "$other":           { ".validate": false }
        }
      },
      "maintenance": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        "site":     { ".validate": "newData.isBoolean()" },
        "explore":  { ".validate": "newData.isBoolean()" },
        "profiles": { ".validate": "newData.isBoolean()" },
        "blogs":    { ".validate": "newData.isBoolean()" },
        "premium":  { ".validate": "newData.isBoolean()" },
        "msg":      { ".validate": "newData.isString() && newData.val().length <= 400" },
        "$other":   { ".validate": false }
      }
    },

    "premium": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$uid": {
        ".read": true,
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        ".validate": "newData.hasChildren(['active'])",
        "active":   { ".validate": "newData.isBoolean()" },
        "plan":     { ".validate": "!newData.exists() || newData.isString()" },
        "since":    { ".validate": "!newData.exists() || newData.isNumber()" },
        "expires":  { ".validate": "!newData.exists() || newData.isNumber()" },
        "count":    { ".validate": "!newData.exists() || newData.isNumber()" },
        "$other":   { ".validate": false }
      }
    },

    "paymentRequests": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$id": {
        ".write": "auth != null && ( ( !data.exists() && newData.child('uid').val() === auth.uid ) || root.child('config/adminEmail').val() === auth.token.email )",
        ".validate": "newData.hasChildren(['uid','method','amount','createdAt'])",
        "uid":       { ".validate": "newData.isString() && newData.val().length <= 64" },
        "username":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "email":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "method":    { ".validate": "newData.isString() && newData.val().length <= 20" },
        "amount":    { ".validate": "newData.isNumber()" },
        "screenshot":{ ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
        "note":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 500)" },
        "status":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "users": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$uid": {
        ".read": "auth != null && ( auth.uid === $uid || root.child('config/adminEmail').val() === auth.token.email )",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['username','email','createdAt'])",
        "username":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 40" },
        "email":     { ".validate": "newData.isString() && newData.val().length <= 160" },
        "salt":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 128)" },
        "passHash":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 256)" },
        "provider":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
        "photo":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "usernames": {
      "$name": {
        ".read": true,
        ".write": "auth != null && ( ( newData.exists() && newData.val() === auth.uid && ( !data.exists() || data.val() === auth.uid ) ) || ( !newData.exists() && data.val() === auth.uid ) )",
        ".validate": "newData.isString() && newData.val().length <= 64"
      }
    },

    "emails": {
      "$enc": {
        ".read": true,
        ".write": "auth != null && ( ( newData.exists() && newData.val() === auth.uid && ( !data.exists() || data.val() === auth.uid ) ) || ( !newData.exists() && data.val() === auth.uid ) )",
        ".validate": "newData.isString() && newData.val().length <= 64"
      }
    },

    "profiles": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$id": {
        ".read": true,
        ".write": "auth != null && ( ( !data.exists() && newData.child('ownerUid').val() === auth.uid ) || ( data.exists() && ( data.child('ownerUid').val() === auth.uid || root.child('config/adminEmail').val() === auth.token.email ) ) )",
        ".validate": "$id.matches(/^[A-Za-z0-9]{1,64}$/) && newData.hasChildren(['ownerUid','updatedAt'])",
        "ownerUid":  { ".validate": "newData.isString() && newData.val().length <= 64" },
        "ownerName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)" },
        "name":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
        "role":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 2000)" },
        "about":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 6000)" },
        "photo":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
        "createdAt": { ".validate": "!newData.exists() || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" }
      }
    },

    "userProfiles": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid",
        "$id": {
          ".validate": "$id.matches(/^[A-Za-z0-9]{1,64}$/) && newData.hasChildren(['updatedAt'])",
          "name":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 200)" },
          "template":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)" },
          "updatedAt": { ".validate": "newData.isNumber()" },
          "$other":    { ".validate": false }
        }
      }
    },

    "blogs": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$id": {
        ".read": true,
        ".write": "auth != null && ( ( !data.exists() && newData.child('ownerUid').val() === auth.uid ) || ( data.exists() && ( data.child('ownerUid').val() === auth.uid || root.child('config/adminEmail').val() === auth.token.email ) ) )",
        ".validate": "$id.matches(/^[A-Za-z0-9]{1,64}$/) && newData.hasChildren(['ownerUid','updatedAt'])",
        "ownerUid":  { ".validate": "newData.isString() && newData.val().length <= 64" },
        "ownerName": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 80)" },
        "title":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
        "subtitle":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1200)" },
        "about":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 6000)" },
        "design":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
        "createdAt": { ".validate": "!newData.exists() || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "posts": {
          "$i": {
            "title": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 400)" },
            "body":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 120000)" }
          }
        }
      }
    },

    "userBlogs": {
      "$uid": {
        ".read": true,
        ".write": "auth != null && auth.uid === $uid",
        "$id": {
          ".validate": "$id.matches(/^[A-Za-z0-9]{1,64}$/) && newData.hasChildren(['updatedAt'])",
          "title":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
          "design":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
          "updatedAt": { ".validate": "newData.isNumber()" },
          "$other":    { ".validate": false }
        }
      }
    },

    "blogIndex": {
      ".read": true,
      "$id": {
        ".write": "auth != null && ( !root.child('blogs/'+$id+'/ownerUid').exists() || root.child('blogs/'+$id+'/ownerUid').val() === auth.uid || root.child('config/adminEmail').val() === auth.token.email )",
        ".validate": "$id.matches(/^[A-Za-z0-9]{1,64}$/) && newData.hasChildren(['updatedAt'])",
        "title":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 300)" },
        "subtitle":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1200)" },
        "author":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 120)" },
        "cover":     { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 4000)" },
        "design":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 20)" },
        "count":     { ".validate": "!newData.exists() || newData.isNumber()" },
        "rSum":      { ".validate": "!newData.exists() || newData.isNumber()" },
        "rCount":    { ".validate": "!newData.exists() || newData.isNumber()" },
        "updatedAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "blogRatings": {
      "$blog": {
        ".read": true,
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 5"
        }
      }
    },

    "articleStats": {
      "$blog": {
        ".read": true,
        "$idx": {
          "views": {
            ".write": true,
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "likes": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid",
              ".validate": "newData.isBoolean()"
            }
          }
        }
      }
    },

    "articleComments": {
      "$blog": {
        ".read": true,
        "$idx": {
          "$cid": {
            ".write": "auth != null && ( ( !data.exists() && newData.child('uid').val() === auth.uid ) || ( data.exists() && ( data.child('uid').val() === auth.uid || root.child('config/adminEmail').val() === auth.token.email ) ) )",
            ".validate": "newData.hasChildren(['text','at'])",
            "uid":  { ".validate": "newData.isString() && newData.val().length <= 64" },
            "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
            "text": { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 1500" },
            "at":   { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        }
      }
    },

    "announcements": {
      ".read": true,
      "$id": {
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        ".validate": "newData.hasChildren(['title','createdAt'])",
        "title":     { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 160" },
        "body":      { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 2000)" },
        "uid":       { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 64)" },
        "by":        { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "$other":    { ".validate": false }
      }
    },

    "analytics": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "total": { ".write": true, ".validate": "newData.isNumber()" },
      "daily":     { "$d": { ".write": true, ".validate": "newData.isNumber()" } },
      "countries": { "$c": { ".write": true, ".validate": "newData.isNumber()" } }
    },

    "presence": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$sid": {
        ".write": true,
        ".validate": "!newData.exists() || newData.hasChild('at')",
        "at":   { ".validate": "newData.isNumber()" },
        "name": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "uid":  { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 64)" },
        "page": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 40)" },
        "$other": { ".validate": false }
      }
    },

    "referrals": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$ref": {
        ".read": true,
        "$uid": { ".write": "auth != null && auth.uid === $uid", ".validate": "newData.isNumber()" }
      }
    },

    "referralRewards": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$uid": {
        ".write": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
        ".validate": "newData.hasChild('at')",
        "at": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "notifySubs": {
      ".read": "auth != null && root.child('config/adminEmail').val() === auth.token.email",
      "$uid": {
        ".read": "auth != null && ( auth.uid === $uid || root.child('config/adminEmail').val() === auth.token.email )",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['at'])",
        "username": { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 60)" },
        "email":    { ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 160)" },
        "enabled":  { ".validate": "!newData.exists() || newData.isBoolean()" },
        "push":     { ".validate": "!newData.exists() || newData.isBoolean()" },
        "at":       { ".validate": "newData.isNumber()" },
        "$other":   { ".validate": false }
      }
    }
  }
}
